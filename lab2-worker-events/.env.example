# RabbitMQ connection used by the event-driven worker to consume communication events from MZinga webhooks.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
EXCHANGE_NAME=mzinga_events_durable
QUEUE_NAME=communications-email-worker
ROUTING_KEY=HOOKSURL_COMMUNICATIONS_AFTERCHANGE

# MZinga application URL and credentials.
# Replace the empty values with your own MZinga admin email and password.
# These credentials are used by the worker to authenticate with MZinga and update communication statuses.
MZINGA_URL=http://localhost:3000
MZINGA_EMAIL=
MZINGA_PASSWORD=

# SMTP server configuration used to send emails.
# For local testing with MailHog, keep SMTP_HOST=localhost and SMTP_PORT=1025.
# Fill SMTP_USERNAME and SMTP_PASSWORD only if your SMTP server requires authentication.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
