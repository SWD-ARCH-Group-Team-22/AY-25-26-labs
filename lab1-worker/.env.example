# MongoDB connection used by the Lab 1 worker to read and update communications directly from the database.
# Replace the empty values with your own local MongoDB URI and database name.
MONGODB_URI=
DATABASE_NAME=

# SMTP server configuration used to send emails.
# For local testing with MailHog, keep SMTP_HOST=localhost and SMTP_PORT=1025.
# Fill SMTP_USERNAME and SMTP_PASSWORD only if your SMTP server requires authentication.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Polling interval, in seconds, used by the worker to check for pending communications.
POLL_INTERVAL_SECONDS=5
